# Filesystem queries on disk files and folders.
# Demonstrates filtering files by extension, path patterns, and size.
# Run with: cop run
import filesystem

# Find all CSV files in the project
predicate csvFile(DiskFile) => DiskFile.Extension:equals('.csv')
let CsvFiles = Disk.DiskFiles:csvFile

foreach CsvFiles => PRINT('CSV file: {item.Name} ({item.Size} bytes)')