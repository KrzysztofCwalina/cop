# Parse a data file and query its content.
# Demonstrates type declarations, JSON parsing, and predicate filtering.
# Run with: cop run
import json

type Person = {
    name : string,
    age : int
}

let Persons = Parse('people.json', [Person])

predicate young(Person) => Person.age < 30
let YoungPeople = Persons:young

foreach YoungPeople => PRINT('{item.name} is {item.age}')