# Parse a data file and query its content.
# Demonstrates type declarations, JSON parsing, and predicate filtering.
# Run with: cop run
import json

type Person = {
    name : string,
    age : int
}

let Persons = Parse('people.json', [Person])

predicate canVote(Person) => Person.age >= 18
let Voters = Persons:canVote

foreach Voters => PRINT('{item.name} is {item.age}')