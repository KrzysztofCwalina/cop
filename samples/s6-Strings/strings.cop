# Single-quote strings
PRINT('Hello from Cop!')

# Triple-quote multi-line strings (raw, auto-indent stripped)
PRINT(
    '''
    =============================
      Welcome to Cop
    =============================
    '''
)

# {text@style} for colored output
PRINT('{Hello @red} {World@green}!')

# Escaped \@ for literal @ in output
PRINT('Contact: admin@example.com')
