# JSON parsing with custom type definitions.
# Demonstrates type declarations, JSON deserialization, and predicate filtering.
# Run with: cop run
import json

# Define a typed schema for JSON records
type Person = {
    name : string,
    age : int
}

# Parse a JSON file into a typed collection
let Persons = Parse('data.json', [Person])

# Filter persons by age using a predicate
predicate canVote(Person) => Person.age >= 18
let Voters = Persons:canVote

foreach Voters => PRINT('{item.name}')