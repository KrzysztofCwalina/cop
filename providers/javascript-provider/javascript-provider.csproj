<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Cop.Providers</RootNamespace>
    <PublishReadyToRun>true</PublishReadyToRun>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\code\code.csproj" />
  </ItemGroup>

  <!-- Copy provider DLL to package lib/ folder after build -->
  <Target Name="CopyToPackageLib" AfterTargets="Build">
    <PropertyGroup>
      <PackageLibDir>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\packages\js\javascript\lib\'))</PackageLibDir>
    </PropertyGroup>
    <MakeDir Directories="$(PackageLibDir)" />
    <Copy SourceFiles="$(OutputPath)javascript-provider.dll" DestinationFolder="$(PackageLibDir)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="$(OutputPath)javascript-provider.deps.json" DestinationFolder="$(PackageLibDir)" SkipUnchangedFiles="true" />
  </Target>

</Project>
