{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "cop",
    "scopeName": "source.cop",
    "patterns": [
        { "include": "#triple-quote-string" },
        { "include": "#doc-comment" },
        { "include": "#block-comment" },
        { "include": "#line-comment" },
        { "include": "#single-quote-string" },
        { "include": "#import-statement" },
        { "include": "#predicate-definition" },
        { "include": "#function-definition" },
        { "include": "#command-definition" },
        { "include": "#type-definition" },
        { "include": "#let-binding" },
        { "include": "#runtime-reference" },
        { "include": "#namespace-reference" },
        { "include": "#declaration-keywords" },
        { "include": "#control-keywords" },
        { "include": "#action-invocation" },
        { "include": "#constants" },
        { "include": "#numbers" },
        { "include": "#operators" }
    ],
    "repository": {
        "triple-quote-string": {
            "name": "string.quoted.other.multiline.cop",
            "begin": "'''",
            "end": "'''",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.string.begin.cop" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.string.end.cop" }
            },
            "patterns": [
                { "include": "#string-template" }
            ]
        },
        "doc-comment": {
            "match": "^\\s*##.*$",
            "name": "comment.block.documentation.cop"
        },
        "block-comment": {
            "name": "comment.block.cop",
            "begin": "^\\s*#\\s*$",
            "end": "^\\s*#\\s*$",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.comment.begin.cop" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.comment.end.cop" }
            }
        },
        "line-comment": {
            "match": "#.*$",
            "name": "comment.line.hash.cop"
        },
        "single-quote-string": {
            "name": "string.quoted.single.cop",
            "begin": "'",
            "end": "'",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.string.begin.cop" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.string.end.cop" }
            },
            "patterns": [
                {
                    "name": "constant.character.escape.cop",
                    "match": "\\\\[\\\\nrt'@]"
                },
                {
                    "name": "constant.character.escape.cop",
                    "match": "\\{\\{|\\}\\}"
                },
                { "include": "#string-template" }
            ]
        },
        "string-template": {
            "begin": "\\{(?!\\{)",
            "end": "\\}",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.template-expression.begin.cop" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.template-expression.end.cop" }
            },
            "contentName": "meta.template-expression.cop",
            "patterns": [
                {
                    "match": "@[a-z][-a-z]*",
                    "name": "entity.other.attribute-name.cop"
                },
                {
                    "match": "\\.",
                    "name": "punctuation.accessor.cop"
                },
                {
                    "match": "[A-Za-z_][A-Za-z0-9_]*",
                    "name": "variable.other.readwrite.cop"
                }
            ]
        },
        "import-statement": {
            "match": "\\b(import)\\s+([a-zA-Z][a-zA-Z0-9-]*)",
            "captures": {
                "1": { "name": "keyword.control.import.cop" },
                "2": { "name": "entity.name.module.cop" }
            }
        },
        "predicate-definition": {
            "match": "\\b(predicate)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*\\(",
            "captures": {
                "1": { "name": "storage.type.predicate.cop" },
                "2": { "name": "entity.name.function.predicate.cop" }
            }
        },
        "function-definition": {
            "match": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*\\(",
            "captures": {
                "1": { "name": "storage.type.function.cop" },
                "2": { "name": "entity.name.function.cop" }
            }
        },
        "command-definition": {
            "match": "\\b(command)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)",
            "captures": {
                "1": { "name": "storage.type.command.cop" },
                "2": { "name": "entity.name.function.command.cop" }
            }
        },
        "type-definition": {
            "match": "\\b(type)\\s+([A-Z][a-zA-Z0-9_]*)",
            "captures": {
                "1": { "name": "storage.type.cop" },
                "2": { "name": "entity.name.type.cop" }
            }
        },
        "let-binding": {
            "match": "\\b(let)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=",
            "captures": {
                "1": { "name": "keyword.control.cop" },
                "2": { "name": "variable.other.readwrite.cop" }
            }
        },
        "runtime-reference": {
            "match": "\\b(runtime)(::)([A-Z][a-zA-Z0-9_]*)",
            "captures": {
                "1": { "name": "support.type.runtime.cop" },
                "2": { "name": "punctuation.accessor.namespace.cop" },
                "3": { "name": "entity.name.type.cop" }
            }
        },
        "namespace-reference": {
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)(::)([a-zA-Z_][a-zA-Z0-9_-]*)",
            "captures": {
                "1": { "name": "entity.name.module.cop" },
                "2": { "name": "punctuation.accessor.namespace.cop" },
                "3": { "name": "entity.name.function.cop" }
            }
        },
        "declaration-keywords": {
            "match": "\\b(predicate|function|command|type|collection)\\b",
            "name": "storage.type.cop"
        },
        "control-keywords": {
            "match": "\\b(import|export|let|foreach|exclude|feed)\\b",
            "name": "keyword.control.cop"
        },
        "action-invocation": {
            "match": "\\b(PRINT|SAVE|RUN)\\b",
            "name": "support.function.builtin.cop"
        },
        "constants": {
            "match": "\\b(true|false|nic)\\b",
            "name": "constant.language.cop"
        },
        "numbers": {
            "match": "\\b\\d+(\\.\\d+)?\\b",
            "name": "constant.numeric.cop"
        },
        "operators": {
            "patterns": [
                {
                    "match": "=>",
                    "name": "keyword.operator.arrow.cop"
                },
                {
                    "match": "&&|\\|\\|",
                    "name": "keyword.operator.logical.cop"
                },
                {
                    "match": "==|!=|>=|<=|>|<",
                    "name": "keyword.operator.comparison.cop"
                },
                {
                    "match": "!(?!=)",
                    "name": "keyword.operator.logical.not.cop"
                }
            ]
        }
    }
}
