# Tests for let declarations, chaining, unions of let-bound collections, and negation.
# Runs against samples/Animals.cs

import csharp

# ── Predicates used by let chains ──
predicate endsClient(Type) => Type.Name:endsWith('Client')
predicate endsService(Type) => Type.Name:endsWith('Service')
predicate containsZzz(Type) => Type.Name:contains('Zzz')

# ── Basic let ──
let public-types = csharp.Types:isPublic
command test-let-basic = ASSERT(public-types, 'let binding should resolve')

# ── Chained let (narrowing) ──
let sealed-public = public-types:isSealed
command test-let-chain-sealed = ASSERT(sealed-public, 'chained let narrows to sealed')

let abstract-public = public-types:isAbstract
command test-let-chain-abstract = ASSERT(abstract-public, 'chained let narrows to abstract')

# ── Chain producing empty ──
let sealed-abstract = sealed-public:isAbstract
command test-let-empty-chain = ASSERT_EMPTY(sealed-abstract, 'sealed+abstract should be empty')

# ── Multiple predicates ──
let clients = public-types:endsClient
command test-let-client = ASSERT(clients, 'should find client types via let')

let services = public-types:endsService
command test-let-service = ASSERT(services, 'should find service types via let')

# ── Deep chain (3 levels) ──
let sealed-clients = clients:isSealed
command test-let-deep = ASSERT(sealed-clients, 'FishClient is a sealed client')

# ── Union of let-bound collections ──
let important = clients + services
command test-let-union = ASSERT(important, 'union of let-chained collections')

# ── Negated filter on let ──
let non-sealed = public-types:!isSealed
command test-let-negated = ASSERT(non-sealed, 'should have non-sealed public types')

# ── Let that produces empty ──
let zzz = csharp.Types:containsZzz
command test-let-empty = ASSERT_EMPTY(zzz, 'no types contain Zzz')
