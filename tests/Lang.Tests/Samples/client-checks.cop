# Client library design checks for C#

predicate client(Type) => Type.Name:endsWith('Client')
predicate clientOptionsType(Type) => Type.Name:endsWith('ClientOptions')
predicate Clients(Types) => client
predicate optionsParam(Parameter) => Parameter.Type:endsWith('Options')
predicate constructorAcceptsOptions(Constructor) => Constructor.Parameters:any(optionsParam)
predicate missingOptionsConstructor(Type) => Type.Constructors:!any(constructorAcceptsOptions)
predicate notSealedOrAbstract(Type) => Type:!isSealed && Type:!isAbstract

predicate cancellationToken(Parameter) => Parameter.Type == 'CancellationToken'
predicate publicAsync(Method) => Method:isPublic && Method:isAsync
predicate missingCancellationToken(Method) => Method.Parameters:!any(cancellationToken)
predicate asyncWithoutCancellation(Type) => Type.Methods.Where(publicAsync):any(missingCancellationToken)

## Client types must have a constructor that accepts an Options parameter
foreach Clients:csharp:missingOptionsConstructor => '{warning:@yellow} {item.Name} should accept an options parameter'

## Client types must be sealed or abstract to prevent unintended inheritance
foreach Clients:csharp:notSealedOrAbstract => '{warning:@yellow} {item.Name} should be sealed or abstract'

## Async methods on client types must accept a CancellationToken parameter
foreach Clients:csharp:asyncWithoutCancellation => '{warning:@yellow} {item.Name} is async without CancellationToken'
