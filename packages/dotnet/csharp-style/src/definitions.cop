# StyleCop predicate definitions for C#

# SA1302: Interface names must begin with 'I' followed by an uppercase letter
predicate interfaceMissingIPrefix(Type) => Type.Kind == 'Interface' && !Type.Name:rx('^I[A-Z]')

# SA1300: Type names must begin with an uppercase letter (PascalCase)
predicate lowercaseTypeName(Type) => Type.Name:rx('^[a-z]')

# SA1300: Public method names must begin with an uppercase letter (PascalCase)
predicate lowercasePublicMethod(Method) => Method.Public && Method.Name:rx('^[a-z]')
predicate hasLowercasePublicMethod(Type) => Type.Methods:any(lowercasePublicMethod)

# SA1402: File may only contain a single type
predicate multipleTypesInFile(Type) => Type.File.Types.Count > 1

# SA1005: Single-line comment must begin with a space after //
predicate commentMissingSpace(Line) => Line.Text:rx('//[^ /!]')

# SA1027: Code must not contain tabs
predicate containsTab(Line) => Line.Text:rx('\t')

# SA1028: Code must not contain trailing whitespace
predicate trailingWhitespace(Line) => Line.Text:rx('[ \t]+$')

# SA1106: Code must not contain empty statements (stray semicolons)
predicate emptyStatement(Line) => Line.Text:rx('^\s*;\s*$')

# SA1120: Comments must contain text (not just //)
predicate emptyComment(Line) => Line.Text:rx('//\s*$')

# SA1122: Use string.Empty for empty strings in comparisons
predicate emptyStringLiteral(Line) => Line.Text:rx('(==|!=)\s*""') || Line.Text:rx('""\s*(==|!=)')

# SA1206: Declaration keywords must follow order (access, static, other)
# Flag common misordering: static before access modifier
predicate wrongModifierOrder(Line) => Line.Text:rx('^\s*(static|sealed|abstract|virtual|override|readonly)\s+(public|private|protected|internal)\s')

# SA1633: File must have a header (first line should be a comment)
predicate missingFileHeader(Line) => Line.Number == 1 && !Line.Text:rx('^(\s*/[/*]|#)')

# SA1200: Using directives must be placed outside the namespace
# This checks if the file has a namespace but usings appear after a namespace declaration
predicate usingInsideNamespace(Line) => Line.Text:rx('^\s*using\s+[A-Z]') && Line.Number > 10

# SA1600: Public elements should be documented (have XML doc comments)
predicate publicUndocumented(Type) => Type.Public && !Type.Documented
predicate undocumentedPublicMethod(Method) => Method.Public && !Method.Documented
predicate hasUndocumentedPublicMethod(Type) => Type.Methods:any(undocumentedPublicMethod)

# SA1401: Fields should be private (non-const public fields are bad)
predicate publicNonConstField(Field) => Field.Public && !Field.Const
predicate hasPublicField(Type) => Type.Fields:any(publicNonConstField)

# .editorconfig naming: private fields should start with _
predicate privateFieldMissingUnderscore(Field) => Field.Private && !Field.Static && !Field.Name:rx('^_')
predicate hasPrivateFieldNamingViolation(Type) => Type.Fields:any(privateFieldMissingUnderscore)

# .editorconfig naming: private static fields should start with s_
predicate staticFieldMissingSPrefix(Field) => Field.Private && Field.Static && !Field.Const && !Field.Name:rx('^s_')
predicate hasStaticFieldNamingViolation(Type) => Type.Fields:any(staticFieldMissingSPrefix)

# .editorconfig naming: constants should be PascalCase
predicate constFieldNotPascalCase(Field) => Field.Const && !Field.Name:rx('^[A-Z]')
predicate hasConstNamingViolation(Type) => Type.Fields:any(constFieldNotPascalCase)

# SA1500: Braces must not be on the same line as the preceding statement
# Detects opening brace at end of line (K&R style) instead of Allman style
predicate braceNotOnOwnLine(Line) => Line.Text:rx('(if|else|for|foreach|while|do|try|catch|finally|switch|lock|using)\s*\(.*\)\s*\{') || Line.Text:rx('(else|try|catch|finally|do)\s*\{')

# SA1503: Braces must not be omitted from control flow
# Detects single-line if/for/while/foreach without braces
predicate missingBraces(Line) => Line.Text:rx('^\s*(if|else if|for|foreach|while)\s*\(.*\)\s*[^{;\s]') || Line.Text:rx('^\s*else\s+[^{i]')

# SA1518: File must end with a single newline
predicate fileMissingTrailingNewline(Line) => Line.File.Types.Count >= 0 && Line.Number == 1 && !Line.File.Path:rx('placeholder')

# SA1600: Public properties should be documented
predicate undocumentedPublicProperty(Property) => Property.Public && !Property.Documented
predicate hasUndocumentedPublicProperty(Type) => Type.Properties:any(undocumentedPublicProperty)
