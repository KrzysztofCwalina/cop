# Cop JSON Package v1.0
# Provides the Parse() function for loading JSON files into typed collections.
# Import with: import json
#
# Usage:
#   type MyRecord = { field : string, count : int }
#   let Records = Parse('data.json', [MyRecord])
#
# Parse() is a built-in function — no type or collection exports needed.
# The user defines types inline and Parse creates ScriptObject instances
# matching the type schema.
